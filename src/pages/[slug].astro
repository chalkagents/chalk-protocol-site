---
import { getCollection, render } from 'astro:content';
import Base from '../layouts/Base.astro';
import { DOCS } from '../lib/docs.mjs';

export async function getStaticPaths() {
  const entries = await getCollection('docs');
  return entries.map((entry) => ({ params: { slug: entry.id }, props: { entry } }));
}

const { entry } = Astro.props;
const { Content, headings } = await render(entry);
const repo = 'https://github.com/chalkagents/chalk-protocol';
const source = `${repo}/blob/main/${entry.data.file}`;
const index = DOCS.findIndex((doc) => doc.id === entry.id);
const prev = index > 0 ? DOCS[index - 1] : null;
const next = index >= 0 && index < DOCS.length - 1 ? DOCS[index + 1] : null;
// "On this page" — H2/H3 only; deeper headings would over-crowd a short doc.
const toc = (headings ?? []).filter((h) => h.depth === 2 || h.depth === 3);
---
<Base
  title={`${entry.data.title} — Chalk Protocol`}
  description={`${entry.data.file} from chalkagents/chalk-protocol, rendered at build time.`}
>
  <div class="doc-layout">
    <aside class="doc-sidebar" aria-label="Docs">
      <p class="rail-label">Docs</p>
      <nav class="doc-nav">
        {DOCS.map((doc) => (
          <a
            href={`/${doc.id}`}
            class:list={['doc-nav-link', { active: doc.id === entry.id }]}
            aria-current={doc.id === entry.id ? 'page' : undefined}
          >{doc.title}</a>
        ))}
      </nav>
    </aside>

    <main class="doc-main">
      <nav class="doc-meta">
        <a href="/">&larr; Chalk Protocol</a>
        <a class="doc-source" href={source}>Source: {entry.data.file}</a>
      </nav>
      <article>
        <Content />
      </article>
      <nav class="doc-pager" aria-label="Docs navigation">
        {prev ? (
          <a class="pager-link prev" href={`/${prev.id}`}>
            <span class="pager-label">Previous</span>
            <span class="pager-title">&larr; {prev.title}</span>
          </a>
        ) : (
          <span class="pager-spacer" />
        )}
        {next ? (
          <a class="pager-link next" href={`/${next.id}`}>
            <span class="pager-label">Next</span>
            <span class="pager-title">{next.title} &rarr;</span>
          </a>
        ) : (
          <span class="pager-spacer" />
        )}
      </nav>
    </main>

    {toc.length > 0 && (
      <aside class="doc-toc" aria-label="On this page">
        <p class="rail-label">On this page</p>
        <nav class="toc-nav">
          {toc.map((h) => (
            <a href={`#${h.slug}`} class:list={['toc-link', `depth-${h.depth}`]} data-toc-target={h.slug}>{h.text}</a>
          ))}
        </nav>
      </aside>
    )}
  </div>
</Base>

<script>
  // Copy buttons on code blocks — read the sibling <pre> at click time (no payload
  // duplication). Fixed labels so a double-click can't stick a transient label.
  for (const btn of document.querySelectorAll<HTMLButtonElement>('.code-copy')) {
    let restore: ReturnType<typeof setTimeout> | undefined;
    btn.addEventListener('click', async () => {
      const pre = btn.parentElement?.querySelector('pre');
      if (!pre) return;
      try {
        await navigator.clipboard.writeText(pre.innerText);
        btn.textContent = 'copied ✓';
        clearTimeout(restore);
        restore = setTimeout(() => { btn.textContent = 'copy'; }, 1200);
      } catch {
        /* clipboard unavailable — the code is selectable */
      }
    });
  }

  // Active TOC entry — highlight the section currently in view.
  const links = new Map<string, HTMLAnchorElement>();
  for (const a of document.querySelectorAll<HTMLAnchorElement>('.toc-link')) {
    const id = a.dataset.tocTarget;
    if (id) links.set(id, a);
  }
  if (links.size > 0 && 'IntersectionObserver' in window) {
    const seen = new Set<string>();
    const obs = new IntersectionObserver(
      (entries) => {
        for (const e of entries) {
          const id = e.target.id;
          if (e.isIntersecting) seen.add(id);
          else seen.delete(id);
        }
        let active: string | undefined;
        for (const id of links.keys()) if (seen.has(id)) { active = id; break; }
        for (const [id, a] of links) a.classList.toggle('active', id === active);
      },
      { rootMargin: '0px 0px -70% 0px', threshold: 0 },
    );
    for (const id of links.keys()) {
      const el = document.getElementById(id);
      if (el) obs.observe(el);
    }
  }
</script>

<style>
  /* Three-column docs layout: left nav / constrained prose / right TOC.
     Rails collapse away below 64rem; prose stays readable at every width. */
  .doc-layout {
    max-width: 84rem;
    margin: 0 auto;
    padding: 2.5rem 1.5rem 3.5rem;
    display: grid;
    grid-template-columns: 1fr;
    gap: 2.5rem;
  }
  @media (min-width: 64rem) {
    .doc-layout {
      grid-template-columns: 12rem minmax(0, 42rem) 13rem;
      justify-content: center;
      gap: 3rem;
      align-items: start;
    }
  }
  .rail-label {
    font-family: var(--mono);
    font-size: 0.72rem;
    text-transform: uppercase;
    letter-spacing: 0.15em;
    color: var(--fg2);
    margin: 0 0 0.8rem;
  }

  /* Left doc nav */
  .doc-sidebar {
    min-width: 0;
  }
  .doc-nav {
    display: flex;
    flex-direction: column;
    gap: 0.15rem;
    border-left: 1px solid var(--border);
  }
  .doc-nav-link {
    font-family: var(--mono);
    font-size: 0.9rem;
    color: var(--fg2);
    text-decoration: none;
    padding: 0.25rem 0.85rem;
    border-left: 2px solid transparent;
    margin-left: -1px;
  }
  .doc-nav-link:hover {
    color: var(--fg);
    text-decoration: none;
  }
  .doc-nav-link.active {
    color: var(--accent);
    text-shadow: none;
    border-left-color: var(--accent);
  }

  /* Right TOC */
  .doc-toc {
    min-width: 0;
  }
  .toc-nav {
    display: flex;
    flex-direction: column;
    gap: 0.15rem;
    border-left: 1px solid var(--border);
  }
  .toc-link {
    font-size: 0.85rem;
    line-height: 1.4;
    color: var(--fg2);
    text-decoration: none;
    padding: 0.2rem 0.75rem;
    border-left: 2px solid transparent;
    margin-left: -1px;
  }
  .toc-link.depth-3 {
    padding-left: 1.5rem;
    font-size: 0.8rem;
  }
  .toc-link:hover {
    color: var(--fg);
    text-decoration: none;
  }
  .toc-link.active {
    color: var(--accent);
    border-left-color: var(--accent);
  }
  @media (min-width: 64rem) {
    /* Pin each rail to an explicit column so placement can NEVER depend on source
       order or the `order` property — this is the fix for the TOC-in-the-middle bug. */
    .doc-sidebar {
      grid-column: 1;
      position: sticky;
      top: 4.5rem;
    }
    .doc-main {
      grid-column: 2;
      order: 0; /* reset the mobile content-first order so placement is truly order-independent */
    }
    .doc-toc {
      grid-column: 3;
      position: sticky;
      top: 4.5rem;
    }
  }

  /* Center column — order:-1 stacks it first on mobile; at desktop it is pinned to
     grid-column 2 (media query above), so order is a no-op there. */
  .doc-main {
    order: -1;
    min-width: 0;
  }
  .doc-meta {
    display: flex;
    justify-content: space-between;
    gap: 0.75rem;
    flex-wrap: wrap;
    margin-bottom: 2rem;
    font-family: var(--mono);
    font-size: 0.85rem;
  }
  .doc-meta a {
    color: var(--accent);
    text-decoration: none;
  }
  .doc-meta a:hover {
    text-decoration: underline;
  }
  .doc-meta .doc-source {
    color: var(--fg2);
  }

  /* Rendered markdown — sans prose at a readable measure */
  article {
    font-size: 1rem;
    line-height: 1.75;
  }
  article :global(h1) {
    font-size: 2.1rem;
    line-height: 1.15;
    letter-spacing: -0.025em;
    margin: 0 0 1rem;
  }
  article :global(h2),
  article :global(h3),
  article :global(h4) {
    letter-spacing: -0.015em;
    margin: 2.4rem 0 0.6rem;
    scroll-margin-top: 5rem;
  }
  article :global(h2) {
    font-size: 1.45rem;
    border-bottom: 1px solid var(--border);
    padding-bottom: 0.4rem;
  }
  article :global(h3) {
    font-size: 1.15rem;
  }
  article :global(p),
  article :global(li) {
    color: var(--fg);
  }
  article :global(a) {
    color: var(--accent);
  }
  article :global(code) {
    font-family: var(--mono);
    font-size: 0.9em;
  }
  article :global(:not(pre) > code) {
    background: var(--panel-2);
    border: 1px solid var(--border);
    border-radius: 0;
    padding: 0.1rem 0.35rem;
    color: var(--accent);
  }

  /* Code block + copy button (from src/lib/code-copy.mjs) */
  article :global(.code-block) {
    position: relative;
    margin: 1.1rem 0;
  }
  article :global(.code-block pre) {
    overflow-x: auto;
    padding: 0.9rem 1.1rem;
    border-radius: 0;
    margin: 0;
  }
  article :global(.code-copy) {
    position: absolute;
    top: 0.5rem;
    right: 0.5rem;
    font-family: var(--mono);
    font-size: 0.75rem;
    color: var(--fg2);
    background: var(--panel-2);
    border: 1px solid var(--border);
    padding: 0.15rem 0.55rem;
    cursor: pointer;
    opacity: 0;
    transition: opacity 0.15s ease;
  }
  article :global(.code-block:hover .code-copy),
  article :global(.code-copy:focus) {
    opacity: 1;
  }
  article :global(.code-copy:hover) {
    color: #0a0700;
    background: var(--accent);
    border-color: var(--accent);
  }

  /* Callouts (from src/lib/callouts.mjs) */
  article :global(.callout) {
    margin: 1.2rem 0;
    padding: 0.8rem 1.1rem;
    border: 1px solid var(--border);
    border-left-width: 3px;
    background: var(--panel-2);
  }
  article :global(.callout-title) {
    margin: 0 0 0.3rem;
    font-family: var(--mono);
    font-size: 0.78rem;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    font-weight: 700;
  }
  article :global(.callout p:last-child) {
    margin-bottom: 0;
  }
  article :global(.callout-note) { border-left-color: var(--accent); }
  article :global(.callout-note .callout-title) { color: var(--accent); }
  article :global(.callout-tip) { border-left-color: var(--accent); }
  article :global(.callout-tip .callout-title) { color: var(--accent); }
  article :global(.callout-important) { border-left-color: var(--accent); }
  article :global(.callout-important .callout-title) { color: var(--accent); }
  article :global(.callout-warning) { border-left-color: var(--accent); }
  article :global(.callout-warning .callout-title) { color: var(--accent); }
  article :global(.callout-caution) { border-left-color: var(--err); }
  article :global(.callout-caution .callout-title) { color: var(--err); }

  /* Plain (non-alert) blockquotes keep the prior styling */
  article :global(blockquote) {
    margin: 1rem 0;
    padding: 0.1rem 1rem;
    border-left: 3px solid var(--accent);
    background: var(--panel-2);
    border-radius: 0;
    color: var(--fg2);
  }
  article :global(table) {
    border-collapse: collapse;
    width: 100%;
    margin: 1rem 0;
    font-size: 0.95rem;
  }
  article :global(th),
  article :global(td) {
    border: 1px solid var(--border);
    padding: 0.45rem 0.7rem;
    text-align: left;
  }
  article :global(th) {
    background: var(--panel-2);
  }
  article :global(hr) {
    border: 0;
    border-top: 1px solid var(--border);
    margin: 2rem 0;
  }
  article :global(img) {
    max-width: 100%;
  }

  /* Heading anchors injected by src/lib/heading-anchors.mjs */
  article :global(.heading-anchor) {
    margin-left: 0.45rem;
    color: var(--fg2);
    font-family: var(--mono);
    font-weight: 400;
    text-decoration: none;
    opacity: 0;
    transition: opacity 0.15s ease;
  }
  article :global(h2:hover .heading-anchor),
  article :global(h3:hover .heading-anchor),
  article :global(h4:hover .heading-anchor),
  article :global(h5:hover .heading-anchor),
  article :global(h6:hover .heading-anchor),
  article :global(.heading-anchor:focus) {
    opacity: 1;
  }
  article :global(.heading-anchor:hover) {
    color: var(--accent);
  }

  /* Prev / next pager */
  .doc-pager {
    display: flex;
    justify-content: space-between;
    gap: 1rem;
    margin-top: 3rem;
    border-top: 1px solid var(--border);
    padding-top: 1.5rem;
  }
  .pager-link {
    display: flex;
    flex-direction: column;
    gap: 0.15rem;
    text-decoration: none;
    border: 1px solid var(--border);
    border-radius: 0;
    padding: 0.7rem 1rem;
    background: var(--panel);
    min-width: 10rem;
  }
  .pager-link:hover {
    border-color: var(--accent);
    box-shadow: 0 0 18px rgba(61, 255, 112, 0.12);
    text-decoration: none;
  }
  .pager-link:hover .pager-title {
    color: var(--accent);
    text-shadow: none;
  }
  .pager-link.next {
    text-align: right;
    margin-left: auto;
  }
  .pager-label {
    font-family: var(--mono);
    font-size: 0.8rem;
    color: var(--fg2);
  }
  .pager-title {
    color: var(--accent);
    font-weight: 600;
  }
</style>
