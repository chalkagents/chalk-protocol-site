---
import { getCollection } from 'astro:content';
import Base from '../../layouts/Base.astro';

const posts = (await getCollection('blog', (p) => !p.data.draft)).sort(
  (a, b) => b.data.date.getTime() - a.data.date.getTime(),
);
const fmt = (d: Date) =>
  d.toLocaleDateString('en-GB', { day: 'numeric', month: 'long', year: 'numeric' });
---
<Base
  title="Blog — Chalk Protocol"
  description="Writing on verifiable AI-generated code, reward hacking, and the gates that keep coding agents honest."
>
  <main class="blog-index">
    <header class="blog-head">
      <p class="eyebrow">Blog</p>
      <h1>Notes on keeping coding agents honest</h1>
      <p class="blog-dek">
        Verifiable AI-generated code, reward hacking, and what it takes to trust work you
        didn't watch being written.
      </p>
    </header>

    {posts.length === 0 ? (
      <p class="blog-empty">No posts yet — check back soon.</p>
    ) : (
      <ul class="post-list">
        {posts.map((post) => (
          <li class="post-item">
            <a class="post-link" href={`/blog/${post.id}`}>
              <p class="post-date">
                <time datetime={post.data.date.toISOString().slice(0, 10)}>{fmt(post.data.date)}</time>
              </p>
              <h2 class="post-title">{post.data.title}</h2>
              <p class="post-desc">{post.data.description}</p>
              <span class="post-more">Read <span aria-hidden="true">&rarr;</span></span>
            </a>
          </li>
        ))}
      </ul>
    )}
  </main>
</Base>

<style>
  .blog-index {
    max-width: 48rem;
    margin: 0 auto;
    padding: 4rem 1.5rem 3rem;
  }
  .blog-head {
    padding-bottom: 2.4rem;
    margin-bottom: 2.4rem;
    border-bottom: 1px solid var(--border);
  }
  .blog-head h1 {
    font-family: var(--display);
    font-weight: 300;
    font-size: clamp(2.2rem, 5vw, 3.2rem);
    line-height: 1.05;
    letter-spacing: -0.02em;
    color: var(--fg);
    margin: 0.3rem 0 0;
    text-wrap: balance;
  }
  .blog-dek {
    margin: 1.2rem 0 0;
    font-size: 1.15rem;
    line-height: 1.6;
    color: var(--fg2);
    max-width: 36rem;
  }
  .blog-empty { color: var(--fg2); }

  .post-list {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }
  .post-link {
    display: block;
    padding: 1.6rem 1.7rem;
    border: 1px solid var(--border);
    background: var(--panel);
    text-decoration: none;
    transition: border-color 0.15s ease, box-shadow 0.15s ease, transform 0.15s ease;
  }
  .post-link:hover {
    border-color: var(--accent);
    box-shadow: 0 0 24px var(--accent-tint);
  }
  .post-date {
    font-family: var(--mono);
    font-size: 0.72rem;
    text-transform: uppercase;
    letter-spacing: 0.14em;
    color: var(--fg3);
    margin: 0 0 0.7rem;
  }
  .post-title {
    font-family: var(--display);
    font-weight: 400;
    font-size: 1.55rem;
    line-height: 1.15;
    letter-spacing: -0.015em;
    color: var(--fg);
    margin: 0;
    text-wrap: balance;
  }
  .post-link:hover .post-title { color: var(--accent); }
  .post-desc {
    margin: 0.7rem 0 0;
    color: var(--fg2);
    line-height: 1.6;
  }
  .post-more {
    display: inline-block;
    margin-top: 1rem;
    font-family: var(--mono);
    font-size: 0.78rem;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--accent);
  }
  .post-more span {
    display: inline-block;
    transition: transform 0.15s ease;
  }
  .post-link:hover .post-more span { transform: translateX(3px); }
</style>
