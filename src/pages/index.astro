---
import Base from '../layouts/Base.astro';

const repo = 'https://github.com/chalkagents/chalk-protocol';
const npm = 'https://www.npmjs.com/package/chalk-protocol';
const docs = [
  { label: 'README', href: `${repo}/blob/main/README.md`, desc: 'What Chalk Protocol is and why it exists.' },
  { label: 'PROTOCOL.md', href: '/protocol', source: `${repo}/blob/main/PROTOCOL.md`, desc: 'The full contract ‚ÄĒ every gate, spelled out.' },
  { label: 'QUICKSTART.md', href: '/quickstart', source: `${repo}/blob/main/QUICKSTART.md`, desc: 'From zero to a gated loop in minutes.' },
  { label: 'RESEARCH.md', href: '/research', source: `${repo}/blob/main/RESEARCH.md`, desc: 'The evidence behind the design.' },
];
const gates = [
  { name: 'Locked test', desc: 'A real test is authored for the acceptance criteria, then locked read-only. The agent cannot weaken or delete it to pass.' },
  { name: 'Verify', desc: 'The real toolchain plus a test-integrity check must print GREEN. The gate decides success ‚ÄĒ never the agent.' },
  { name: 'Adversarial review', desc: 'A second agent tries to refute the change. Every blocking finding must be fixed before it passes.' },
  { name: 'Merge gate', desc: '`chalk done` only succeeds when verify is green, locked tests are untouched, and review passed.' },
];
const steps = [
  { cmd: 'chalk next', desc: 'find the one task to work on' },
  { cmd: 'chalk context <id>', desc: 'read the acceptance criteria and at-risk tests before coding' },
  { cmd: 'chalk start <id>', desc: 'begin ‚ÄĒ it refuses tasks with no acceptance criteria' },
  { cmd: 'write code', desc: 'satisfy the criteria, keep the diff small' },
  { cmd: 'chalk verify', desc: 'loop until the gate prints GREEN' },
  { cmd: 'chalk review <id>', desc: 'survive the adversarial reviewer' },
  { cmd: 'chalk done <id>', desc: 'the merge gate closes the task' },
];

// The money shot: an agent tries to self-declare done and the gate refuses.
// Timed as a typed session ‚ÄĒ commands type out, output prints after.
const session = [
  { type: 'cmd', text: 'chalk done task-4f2' },
  { type: 'err', text: '‚úó GATE P4: cannot mark done ‚ÄĒ verify is RED. The gate decides, not you.' },
  { type: 'cmd', text: 'chalk verify' },
  { type: 'err', text: '‚úó test  FAIL  (2 failing)' },
  { type: 'cmd', text: 'vim src/gate.mjs        # fix it for real' },
  { type: 'cmd', text: 'chalk verify' },
  { type: 'ok', text: '‚úď GREEN' },
  { type: 'cmd', text: 'chalk done task-4f2' },
  { type: 'ok', text: '‚úď done ‚ÄĒ the gate decided, not the model.' },
];
const CPS = 30; // typed chars per second
let t = 0.8;
const sessionLines = session.map((line) => {
  const dur = line.type === 'cmd' ? Math.max(0.45, line.text.length / CPS) : 0;
  const delay = t;
  t += line.type === 'cmd' ? dur + 0.25 : 0.45;
  return { ...line, delay: +delay.toFixed(2), dur: +dur.toFixed(2), n: line.text.length };
});
const cursorDelay = +t.toFixed(2);

const ascii = ` ‚Ėą‚Ėą‚Ėą‚Ėą‚Ėą‚Ėą‚ēó‚Ėą‚Ėą‚ēó  ‚Ėą‚Ėą‚ēó ‚Ėą‚Ėą‚Ėą‚Ėą‚Ėą‚ēó ‚Ėą‚Ėą‚ēó     ‚Ėą‚Ėą‚ēó  ‚Ėą‚Ėą‚ēó
‚Ėą‚Ėą‚ēĒ‚ēź‚ēź‚ēź‚ēź‚ēĚ‚Ėą‚Ėą‚ēĎ  ‚Ėą‚Ėą‚ēĎ‚Ėą‚Ėą‚ēĒ‚ēź‚ēź‚Ėą‚Ėą‚ēó‚Ėą‚Ėą‚ēĎ     ‚Ėą‚Ėą‚ēĎ ‚Ėą‚Ėą‚ēĒ‚ēĚ
‚Ėą‚Ėą‚ēĎ     ‚Ėą‚Ėą‚Ėą‚Ėą‚Ėą‚Ėą‚Ėą‚ēĎ‚Ėą‚Ėą‚Ėą‚Ėą‚Ėą‚Ėą‚Ėą‚ēĎ‚Ėą‚Ėą‚ēĎ     ‚Ėą‚Ėą‚Ėą‚Ėą‚Ėą‚ēĒ‚ēĚ
‚Ėą‚Ėą‚ēĎ     ‚Ėą‚Ėą‚ēĒ‚ēź‚ēź‚Ėą‚Ėą‚ēĎ‚Ėą‚Ėą‚ēĒ‚ēź‚ēź‚Ėą‚Ėą‚ēĎ‚Ėą‚Ėą‚ēĎ     ‚Ėą‚Ėą‚ēĒ‚ēź‚Ėą‚Ėą‚ēó
‚ēö‚Ėą‚Ėą‚Ėą‚Ėą‚Ėą‚Ėą‚ēó‚Ėą‚Ėą‚ēĎ  ‚Ėą‚Ėą‚ēĎ‚Ėą‚Ėą‚ēĎ  ‚Ėą‚Ėą‚ēĎ‚Ėą‚Ėą‚Ėą‚Ėą‚Ėą‚Ėą‚Ėą‚ēó‚Ėą‚Ėą‚ēĎ  ‚Ėą‚Ėą‚ēó
 ‚ēö‚ēź‚ēź‚ēź‚ēź‚ēź‚ēĚ‚ēö‚ēź‚ēĚ  ‚ēö‚ēź‚ēĚ‚ēö‚ēź‚ēĚ  ‚ēö‚ēź‚ēĚ‚ēö‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēĚ‚ēö‚ēź‚ēĚ  ‚ēö‚ēź‚ēĚ`;
---
<Base
  title="Chalk Protocol ‚ÄĒ ship agent-written code through gates, not vibes"
  description="Chalk Protocol drives coding agents through a gated loop: specced task, locked test, verify, adversarial review, merge gate."
>
  <main>
    <section class="hero">
      <div class="hero-copy">
        <pre class="ascii" aria-hidden="true">{ascii}</pre>
        <h1 class="wordmark">Chalk Protocol</h1>
        <p class="pitch">
          Ship agent-written code through gates, not vibes ‚ÄĒ a locked spec decides success, not the model.
        </p>
        <p class="sub">
          Chalk turns an unattended coding agent into a disciplined contributor: every change lands
          through a gated loop it cannot talk its way around.
        </p>
        <div class="install">
          <pre class="install-cmd"><code><span class="prompt" aria-hidden="true">$ </span>npm install -g chalk-protocol</code></pre>
          <button class="copy" data-copy="npm install -g chalk-protocol" aria-label="Copy install command">[ copy ]</button>
        </div>
        <p class="cta">
          <a class="button" href="/quickstart">[ get started ]</a>
          <a class="button" href={repo}>[ github ]</a>
          <a class="button" href={npm}>[ npm ]</a>
        </p>
      </div>

      <div class="terminal hero-session" role="img" aria-label="A chalk session: the gate refuses an unverified done">
        <div class="terminal-bar">
          <span class="dot red"></span>
          <span class="dot yellow"></span>
          <span class="dot green"></span>
          <span class="terminal-title">chalk ‚ÄĒ zsh</span>
        </div>
        <div class="session">
          {sessionLines.map((line) =>
            line.type === 'cmd' ? (
              <div class="line cmd" style={`--d:${line.delay}s;--dur:${line.dur}s;--n:${line.n}`}>
                <span class="prompt" aria-hidden="true">$ </span><span
                  class="txt"
                  style={`animation-timing-function:steps(${line.n}, end)`}
                >{line.text}</span>
              </div>
            ) : (
              <div class={`line out ${line.type}`} style={`--d:${line.delay}s`}>{line.text}</div>
            )
          )}
          <div class="line prompt-line" style={`--d:${cursorDelay}s`}>
            <span class="prompt" aria-hidden="true">$ </span><span class="cursor" aria-hidden="true">‚Ėć</span>
          </div>
        </div>
      </div>
    </section>

    <section class="loop" id="the-loop">
      <p class="eyebrow" aria-hidden="true">$ chalk gates</p>
      <h2>The loop ‚ÄĒ four gates every change must clear</h2>
      <p class="section-sub">A specced task enters the loop; nothing merges until all four gates say so.</p>
      <div class="terminal">
        <div class="terminal-bar">
          <span class="dot red"></span>
          <span class="dot yellow"></span>
          <span class="dot green"></span>
          <span class="terminal-title">chalk verify ‚ÄĒ 4 gates</span>
        </div>
        <ol class="gates">
          {gates.map((gate, i) => (
            <li>
              <span class="gate-index">[{i + 1}/4]</span>
              <strong>{gate.name}</strong>
              <span class="gate-desc">{gate.desc}</span>
            </li>
          ))}
        </ol>
      </div>
    </section>

    <section class="quickstart" id="quickstart">
      <p class="eyebrow" aria-hidden="true">$ cat quickstart</p>
      <h2>Quickstart</h2>
      <p class="section-sub">The per-task loop, start to merge.</p>
      <ol class="steps">
        {steps.map((step, i) => (
          <li>
            <span class="step-no">{String(i + 1).padStart(2, '0')}</span>
            <code>{step.cmd}</code>
            <span class="step-desc">{step.desc}</span>
          </li>
        ))}
      </ol>
    </section>

    <section class="docs" id="docs">
      <p class="eyebrow" aria-hidden="true">$ ls docs/</p>
      <h2>Docs</h2>
      <p class="section-sub">
        Rendered here at build time from the parent repo ‚ÄĒ the source of truth this site cannot drift from.
      </p>
      <ul class="doc-links">
        {docs.map((doc) => (
          <li>
            <div class="doc-head">
              <a href={doc.href}>{doc.label}</a>
              {doc.source && <a class="source" href={doc.source}>[source]</a>}
            </div>
            <span class="doc-desc">{doc.desc}</span>
          </li>
        ))}
      </ul>
    </section>
  </main>
</Base>

<script>
  const btn = document.querySelector<HTMLButtonElement>('.copy');
  let restore: ReturnType<typeof setTimeout> | undefined;
  btn?.addEventListener('click', async () => {
    try {
      await navigator.clipboard.writeText(btn.dataset.copy ?? '');
      // Fixed labels, not a saved snapshot ‚ÄĒ a double-click inside the restore window
      // must never capture '[ copied ‚úď ]' as the label to restore to.
      btn.textContent = '[ copied ‚úď ]';
      clearTimeout(restore);
      restore = setTimeout(() => { btn.textContent = '[ copy ]'; }, 1200);
    } catch {
      /* clipboard unavailable ‚ÄĒ the command is selectable text right next to the button */
    }
  });
</script>

<style>
  main {
    max-width: 68rem;
    margin: 0 auto;
    padding: 0 1.5rem 4rem;
  }
  section + section {
    margin-top: 6rem;
  }
  .eyebrow {
    font-family: var(--mono);
    font-size: 0.8rem;
    color: var(--muted);
    margin: 0 0 0.35rem;
    letter-spacing: 0.02em;
  }
  h2 {
    font-size: 1.6rem;
    margin: 0 0 0.4rem;
    max-width: 42rem;
  }
  .section-sub {
    color: var(--muted);
    margin: 0 0 1.6rem;
    font-size: 1rem;
    max-width: 42rem;
  }
  .prompt {
    color: var(--amber);
    user-select: none;
  }

  /* ---- Hero ---- */
  .hero {
    padding: 4rem 0 0;
    display: grid;
    grid-template-columns: 1fr;
    gap: 2.5rem;
    align-items: start;
  }
  @media (min-width: 64rem) {
    .hero {
      grid-template-columns: minmax(0, 27rem) minmax(0, 1fr);
      gap: 3rem;
    }
  }
  .ascii {
    margin: 0 0 0.4rem;
    font-family: var(--mono);
    font-size: clamp(0.42rem, 1.55vw, 0.7rem);
    line-height: 1.15;
    color: var(--phosphor);
    text-shadow: var(--glow-strong);
    overflow: hidden;
  }
  .wordmark {
    font-family: var(--mono);
    font-size: 0.82rem;
    letter-spacing: 0.5em;
    text-transform: uppercase;
    color: var(--amber);
    text-shadow: var(--glow-amber);
    margin: 0 0 1.5rem;
    font-weight: 500;
  }
  .pitch {
    font-size: clamp(1.3rem, 2.6vw, 1.55rem);
    line-height: 1.4;
    font-weight: 700;
    letter-spacing: -0.015em;
    color: var(--ink);
    margin: 0 0 0.9rem;
  }
  .sub {
    color: var(--muted);
    font-size: 1.02rem;
    margin: 0 0 1.75rem;
    max-width: 32rem;
  }
  .install {
    display: flex;
    align-items: stretch;
    gap: 0;
    margin: 0 0 1.4rem;
    max-width: 100%;
  }
  .install-cmd {
    margin: 0;
    background: var(--bg-inset);
    border: 1px solid var(--border);
    padding: 0.6rem 0.9rem;
    overflow-x: auto;
  }
  .install-cmd code {
    font-size: 0.9rem;
    color: var(--phosphor);
    text-shadow: var(--glow);
    white-space: nowrap;
  }
  .copy {
    font-family: var(--mono);
    font-size: 0.85rem;
    background: var(--bg-raised);
    color: var(--amber);
    border: 1px solid var(--border);
    border-left: 0;
    padding: 0 0.8rem;
    cursor: pointer;
    white-space: nowrap;
  }
  .copy:hover {
    background: var(--amber);
    color: #0a0700;
  }
  .cta {
    display: flex;
    gap: 0.6rem;
    flex-wrap: wrap;
    margin: 0;
    font-family: var(--mono);
  }
  .button {
    color: var(--amber);
    font-size: 0.92rem;
    padding: 0.15rem 0.2rem;
  }
  .button:hover {
    background: var(--amber);
    color: #0a0700;
    text-decoration: none;
  }

  /* ---- Terminal frames ---- */
  .terminal {
    background: var(--bg-inset);
    border: 1px solid var(--border);
    box-shadow:
      0 0 0 1px rgba(0, 0, 0, 0.6),
      0 0 34px rgba(61, 255, 112, 0.07),
      0 18px 50px rgba(0, 0, 0, 0.5);
    overflow: hidden;
  }
  .terminal-bar {
    display: flex;
    align-items: center;
    gap: 0.45rem;
    padding: 0.55rem 1rem;
    background: var(--bg-raised);
    border-bottom: 1px solid var(--border-dim);
  }
  .dot {
    width: 0.65rem;
    height: 0.65rem;
    border-radius: 50%;
    background: var(--border);
  }
  .dot.red { background: #a33; }
  .dot.yellow { background: #a80; }
  .dot.green { background: #183; }
  .terminal-title {
    margin-left: 0.6rem;
    font-family: var(--mono);
    font-size: 0.78rem;
    color: var(--muted);
  }

  /* ---- Hero session (typed animation) ---- */
  .session {
    padding: 1.1rem 1.2rem 1.3rem;
    font-family: var(--mono);
    font-size: 0.92rem;
    line-height: 1.9;
    min-height: 15rem;
    /* Long command lines scroll like a real terminal ‚ÄĒ never clip silently. */
    overflow-x: auto;
  }
  @media (max-width: 30rem) {
    .session {
      font-size: 0.8rem;
    }
  }
  .line {
    white-space: pre-wrap;
    word-break: break-word;
  }
  .line.cmd {
    white-space: pre;
  }
  .line .txt {
    display: inline-block;
    overflow: hidden;
    white-space: pre;
    vertical-align: bottom;
  }
  .line.out.err {
    color: var(--red);
    text-shadow: 0 0 8px rgba(255, 92, 92, 0.35);
  }
  .line.out.ok {
    color: var(--phosphor);
    text-shadow: var(--glow);
  }
  .cursor {
    color: var(--phosphor);
    text-shadow: var(--glow);
  }
  @media (prefers-reduced-motion: no-preference) {
    .line {
      opacity: 0;
      animation: line-in 0s forwards;
      animation-delay: var(--d);
    }
    .line.cmd .txt {
      width: 0;
      animation: type var(--dur) steps(24, end) forwards;
      animation-delay: var(--d);
    }
    .cursor {
      animation: blink-cursor 1s step-end infinite;
    }
  }
  @keyframes line-in {
    to { opacity: 1; }
  }
  @keyframes type {
    from { width: 0; }
    to { width: calc(var(--n) * 1ch); }
  }
  @keyframes blink-cursor {
    0%, 100% { visibility: visible; }
    50% { visibility: hidden; }
  }

  /* ---- Gates ---- */
  .gates {
    list-style: none;
    margin: 0;
    padding: 1.35rem 1.4rem 1.5rem;
    display: grid;
    gap: 1.15rem;
    font-family: var(--mono);
    font-size: 0.92rem;
  }
  .gate-index {
    color: var(--amber);
    margin-right: 0.5rem;
  }
  .gates strong {
    color: var(--phosphor);
    text-shadow: var(--glow);
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }
  .gate-desc {
    display: block;
    font-family: var(--sans);
    color: var(--muted);
    font-size: 0.97rem;
    line-height: 1.6;
    margin-top: 0.2rem;
    padding-left: 3.4rem;
    max-width: 40rem;
  }

  /* ---- Quickstart ---- */
  .steps {
    list-style: none;
    padding: 0;
    display: grid;
    gap: 0;
    margin: 1.25rem 0 0;
    border: 1px solid var(--border);
    background: var(--bg-inset);
  }
  .steps li {
    display: flex;
    align-items: baseline;
    gap: 0.9rem;
    flex-wrap: wrap;
    padding: 0.7rem 1rem;
    font-size: 0.95rem;
  }
  .steps li + li {
    border-top: 1px solid var(--border-dim);
  }
  .step-no {
    font-family: var(--mono);
    color: var(--muted);
    font-size: 0.8rem;
    user-select: none;
  }
  .steps code {
    color: var(--phosphor);
    min-width: 11rem;
    font-size: 0.9rem;
  }
  .step-desc {
    font-family: var(--sans);
    color: var(--muted);
    font-size: 0.95rem;
  }

  /* ---- Docs ---- */
  .doc-links {
    list-style: none;
    padding: 0;
    margin: 1.25rem 0 0;
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(16rem, 1fr));
    gap: 0.75rem;
  }
  .doc-links li {
    border: 1px solid var(--border);
    background: var(--bg-inset);
    padding: 0.9rem 1rem;
  }
  .doc-links li:hover {
    border-color: var(--phosphor);
    box-shadow: 0 0 18px rgba(61, 255, 112, 0.12);
  }
  .doc-head {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    gap: 0.5rem;
    margin-bottom: 0.25rem;
  }
  .doc-links a {
    color: var(--amber);
    font-family: var(--mono);
    font-weight: 700;
  }
  .doc-links a.source {
    color: var(--muted);
    font-weight: 400;
    font-size: 0.82em;
  }
  .doc-desc {
    font-family: var(--sans);
    color: var(--muted);
    font-size: 0.95rem;
  }
</style>
