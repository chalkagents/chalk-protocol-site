---
import Base from '../layouts/Base.astro';

const repo = 'https://github.com/chalkagents/chalk-protocol';
const npm = 'https://www.npmjs.com/package/chalk-protocol';
const docs = [
  { label: 'README', href: `${repo}/blob/main/README.md`, desc: 'What Chalk Protocol is and why it exists.' },
  { label: 'PROTOCOL.md', href: '/protocol', source: `${repo}/blob/main/PROTOCOL.md`, desc: 'The full contract вҖ” every gate, spelled out.' },
  { label: 'QUICKSTART.md', href: '/quickstart', source: `${repo}/blob/main/QUICKSTART.md`, desc: 'From zero to a gated loop in minutes.' },
  { label: 'RESEARCH.md', href: '/research', source: `${repo}/blob/main/RESEARCH.md`, desc: 'The evidence behind the design.' },
];
const gates = [
  { name: 'Locked test', desc: 'A real test is authored for the acceptance criteria, then locked read-only. The agent cannot weaken or delete it to pass.' },
  { name: 'Verify', desc: 'The real toolchain plus a test-integrity check must print GREEN. The gate decides success вҖ” never the agent.' },
  { name: 'Adversarial review', desc: 'A second agent tries to refute the change. Every blocking finding must be fixed before it passes.' },
  { name: 'Merge gate', desc: '`chalk done` only succeeds when verify is green, locked tests are untouched, and review passed.' },
];
// The four levers as a feature grid вҖ” name + one-line tagline + where to read more.
const levers = [
  { name: 'Locked test', tag: 'A real test, locked read-only. The agent canвҖҷt weaken the spec to pass.', href: '/protocol' },
  { name: 'Verify', tag: 'The real toolchain decides GREEN вҖ” never the agentвҖҷs self-report.', href: '/protocol' },
  { name: 'Adversarial review', tag: 'A second agent tries to refute the change before it can land.', href: '/protocol' },
  { name: 'Merge gate', tag: 'Nothing merges until verify is green, locks intact, review passed.', href: '/quickstart' },
];
// Before/after вҖ” the value made legible without watching the animation.
const without = [
  'Agent marks the task done',
  'The failing test was quietly deleted',
  'Review never happened',
  'The bug ships',
];
const withChalk = [
  'chalk done refuses вҖ” verify is RED',
  'Locked tests canвҖҷt be touched',
  'An adversary must sign off first',
  'The gate closes only on real green',
];
// Honest trust: the agents Chalk drives (it's BYO-executor), not fabricated stars.
const agents = ['Claude Code', 'Cursor', 'opencode', 'aider'];
const steps = [
  { cmd: 'chalk next', desc: 'find the one task to work on' },
  { cmd: 'chalk context <id>', desc: 'read the acceptance criteria and at-risk tests before coding' },
  { cmd: 'chalk start <id>', desc: 'begin вҖ” it refuses tasks with no acceptance criteria' },
  { cmd: 'write code', desc: 'satisfy the criteria, keep the diff small' },
  { cmd: 'chalk verify', desc: 'loop until the gate prints GREEN' },
  { cmd: 'chalk review <id>', desc: 'survive the adversarial reviewer' },
  { cmd: 'chalk done <id>', desc: 'the merge gate closes the task' },
];

// The money shot: an agent tries to self-declare done and the gate refuses.
// Timed as a typed session вҖ” commands type out, output prints after.
const session = [
  { type: 'cmd', text: 'chalk done task-4f2' },
  { type: 'err', text: 'вң— GATE P4: cannot mark done вҖ” verify is RED. The gate decides, not you.' },
  { type: 'cmd', text: 'chalk verify' },
  { type: 'err', text: 'вң— test  FAIL  (2 failing)' },
  { type: 'cmd', text: 'vim src/gate.mjs        # fix it for real' },
  { type: 'cmd', text: 'chalk verify' },
  { type: 'ok', text: 'вң“ GREEN' },
  { type: 'cmd', text: 'chalk done task-4f2' },
  { type: 'ok', text: 'вң“ done вҖ” the gate decided, not the model.' },
];
const CPS = 30; // typed chars per second
let t = 0.8;
const sessionLines = session.map((line) => {
  const dur = line.type === 'cmd' ? Math.max(0.45, line.text.length / CPS) : 0;
  const delay = t;
  t += line.type === 'cmd' ? dur + 0.25 : 0.45;
  return { ...line, delay: +delay.toFixed(2), dur: +dur.toFixed(2), n: line.text.length };
});
const cursorDelay = +t.toFixed(2);

const ascii = ` в–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв•—в–Ҳв–Ҳв•—  в–Ҳв–Ҳв•— в–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв•— в–Ҳв–Ҳв•—     в–Ҳв–Ҳв•—  в–Ҳв–Ҳв•—
в–Ҳв–Ҳв•”в•җв•җв•җв•җв•қв–Ҳв–Ҳв•‘  в–Ҳв–Ҳв•‘в–Ҳв–Ҳв•”в•җв•җв–Ҳв–Ҳв•—в–Ҳв–Ҳв•‘     в–Ҳв–Ҳв•‘ в–Ҳв–Ҳв•”в•қ
в–Ҳв–Ҳв•‘     в–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв•‘в–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв•‘в–Ҳв–Ҳв•‘     в–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв•”в•қ
в–Ҳв–Ҳв•‘     в–Ҳв–Ҳв•”в•җв•җв–Ҳв–Ҳв•‘в–Ҳв–Ҳв•”в•җв•җв–Ҳв–Ҳв•‘в–Ҳв–Ҳв•‘     в–Ҳв–Ҳв•”в•җв–Ҳв–Ҳв•—
в•ҡв–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв•—в–Ҳв–Ҳв•‘  в–Ҳв–Ҳв•‘в–Ҳв–Ҳв•‘  в–Ҳв–Ҳв•‘в–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв•—в–Ҳв–Ҳв•‘  в–Ҳв–Ҳв•—
 в•ҡв•җв•җв•җв•җв•җв•қв•ҡв•җв•қ  в•ҡв•җв•қв•ҡв•җв•қ  в•ҡв•җв•қв•ҡв•җв•җв•җв•җв•җв•җв•қв•ҡв•җв•қ  в•ҡв•җв•қ`;
---
<Base
  title="Chalk Protocol вҖ” ship agent-written code through gates, not vibes"
  description="Chalk Protocol drives coding agents through a gated loop: specced task, locked test, verify, adversarial review, merge gate."
>
  <main>
    <section class="hero">
      <div class="hero-copy">
        <pre class="ascii" aria-hidden="true">{ascii}</pre>
        <p class="wordmark" aria-hidden="true">Chalk Protocol</p>
        <h1 class="headline">The quality gate for AI coding agents.</h1>
        <p class="enemy">AI agents will tell you theyвҖҷre done. Chalk makes them prove it.</p>
        <p class="pitch">
          Ship agent-written code through gates, not vibes вҖ” a locked spec decides success, not the model.
        </p>
        <p class="sub">
          Chalk turns an unattended coding agent into a disciplined contributor: every change lands
          through a gated loop it cannot talk its way around.
        </p>
        <div class="install">
          <pre class="install-cmd"><code><span class="prompt" aria-hidden="true">$ </span>npm install -g chalk-protocol</code></pre>
          <button class="copy" data-copy="npm install -g chalk-protocol" aria-label="Copy install command">[ copy ]</button>
        </div>
        <p class="cta">
          <a class="button" href="/quickstart">[ get started ]</a>
          <a class="button" href={repo}>[ github ]</a>
          <a class="button" href={npm}>[ npm ]</a>
        </p>
        <div class="trust">
          <span class="trust-label">Works with any agent</span>
          <ul class="trust-agents">
            {agents.map((a) => <li>{a}</li>)}
          </ul>
          <p class="trust-note">Bring your own executor. Chalk is the referee вҖ” and it drives itself: this site ships through the same four gates.</p>
        </div>
      </div>

      <div class="terminal hero-session" role="img" aria-label="A chalk session: the gate refuses an unverified done">
        <div class="terminal-bar">
          <span class="dot red"></span>
          <span class="dot yellow"></span>
          <span class="dot green"></span>
          <span class="terminal-title">chalk вҖ” zsh</span>
        </div>
        <div class="session">
          {sessionLines.map((line) =>
            line.type === 'cmd' ? (
              <div class="line cmd" style={`--d:${line.delay}s;--dur:${line.dur}s;--n:${line.n}`}>
                <span class="prompt" aria-hidden="true">$ </span><span
                  class="txt"
                  style={`animation-timing-function:steps(${line.n}, end)`}
                >{line.text}</span>
              </div>
            ) : (
              <div class={`line out ${line.type}`} style={`--d:${line.delay}s`}>{line.text}</div>
            )
          )}
          <div class="line prompt-line" style={`--d:${cursorDelay}s`}>
            <span class="prompt" aria-hidden="true">$ </span><span class="cursor" aria-hidden="true">в–Қ</span>
          </div>
        </div>
      </div>
    </section>

    <section class="levers" id="levers">
      <p class="eyebrow" aria-hidden="true">$ chalk gates --list</p>
      <h2>Four levers, one rule: the agent never certifies itself</h2>
      <p class="section-sub">Each lever closes a way an agent can fake вҖңdone.вҖқ Together they make success an external fact.</p>
      <ul class="lever-grid">
        {levers.map((lever, i) => (
          <li class="lever-card">
            <span class="lever-no" aria-hidden="true">{String(i + 1).padStart(2, '0')}</span>
            <h3>{lever.name}</h3>
            <p>{lever.tag}</p>
            <a class="lever-link" href={lever.href}>Read more вҶ’</a>
          </li>
        ))}
      </ul>
    </section>

    <section class="compare" id="why">
      <p class="eyebrow" aria-hidden="true">$ diff --without --with</p>
      <h2>The difference a gate makes</h2>
      <p class="section-sub">The same agent, the same task вҖ” one path ships a bug, the other canвҖҷt.</p>
      <div class="compare-grid">
        <div class="compare-col without">
          <h3><span class="mark" aria-hidden="true">вң—</span> Agent without Chalk</h3>
          <ul>
            {without.map((line) => <li>{line}</li>)}
          </ul>
        </div>
        <div class="compare-col with">
          <h3><span class="mark" aria-hidden="true">вң“</span> Agent with Chalk</h3>
          <ul>
            {withChalk.map((line) => <li><code>{line}</code></li>)}
          </ul>
        </div>
      </div>
    </section>

    <section class="loop" id="the-loop">
      <p class="eyebrow" aria-hidden="true">$ chalk gates</p>
      <h2>The loop вҖ” four gates every change must clear</h2>
      <p class="section-sub">A specced task enters the loop; nothing merges until all four gates say so.</p>
      <div class="terminal">
        <div class="terminal-bar">
          <span class="dot red"></span>
          <span class="dot yellow"></span>
          <span class="dot green"></span>
          <span class="terminal-title">chalk verify вҖ” 4 gates</span>
        </div>
        <ol class="gates">
          {gates.map((gate, i) => (
            <li>
              <span class="gate-index">[{i + 1}/4]</span>
              <strong>{gate.name}</strong>
              <span class="gate-desc">{gate.desc}</span>
            </li>
          ))}
        </ol>
      </div>
    </section>

    <section class="quickstart" id="quickstart">
      <p class="eyebrow" aria-hidden="true">$ cat quickstart</p>
      <h2>Quickstart</h2>
      <p class="section-sub">The per-task loop, start to merge.</p>
      <ol class="steps">
        {steps.map((step, i) => (
          <li>
            <span class="step-no">{String(i + 1).padStart(2, '0')}</span>
            <code>{step.cmd}</code>
            <span class="step-desc">{step.desc}</span>
          </li>
        ))}
      </ol>
    </section>

    <section class="docs" id="docs">
      <p class="eyebrow" aria-hidden="true">$ ls docs/</p>
      <h2>Docs</h2>
      <p class="section-sub">
        Rendered here at build time from the parent repo вҖ” the source of truth this site cannot drift from.
      </p>
      <ul class="doc-links">
        {docs.map((doc) => (
          <li>
            <div class="doc-head">
              <a href={doc.href}>{doc.label}</a>
              {doc.source && <a class="source" href={doc.source}>[source]</a>}
            </div>
            <span class="doc-desc">{doc.desc}</span>
          </li>
        ))}
      </ul>
    </section>
  </main>
</Base>

<script>
  const btn = document.querySelector<HTMLButtonElement>('.copy');
  let restore: ReturnType<typeof setTimeout> | undefined;
  btn?.addEventListener('click', async () => {
    try {
      await navigator.clipboard.writeText(btn.dataset.copy ?? '');
      // Fixed labels, not a saved snapshot вҖ” a double-click inside the restore window
      // must never capture '[ copied вң“ ]' as the label to restore to.
      btn.textContent = '[ copied вң“ ]';
      clearTimeout(restore);
      restore = setTimeout(() => { btn.textContent = '[ copy ]'; }, 1200);
    } catch {
      /* clipboard unavailable вҖ” the command is selectable text right next to the button */
    }
  });
</script>

<style>
  main {
    max-width: 68rem;
    margin: 0 auto;
    padding: 0 1.5rem 4rem;
  }
  section + section {
    margin-top: 6rem;
  }
  .eyebrow {
    font-family: var(--mono);
    font-size: 0.8rem;
    color: var(--muted);
    margin: 0 0 0.35rem;
    letter-spacing: 0.02em;
  }
  h2 {
    font-size: 1.6rem;
    margin: 0 0 0.4rem;
    max-width: 42rem;
  }
  .section-sub {
    color: var(--muted);
    margin: 0 0 1.6rem;
    font-size: 1rem;
    max-width: 42rem;
  }
  .prompt {
    color: var(--amber);
    user-select: none;
  }

  /* ---- Hero ---- */
  .hero {
    padding: 4rem 0 0;
    display: grid;
    grid-template-columns: 1fr;
    gap: 2.5rem;
    align-items: start;
  }
  @media (min-width: 64rem) {
    .hero {
      grid-template-columns: minmax(0, 27rem) minmax(0, 1fr);
      gap: 3rem;
    }
  }
  .ascii {
    margin: 0 0 0.4rem;
    font-family: var(--mono);
    font-size: clamp(0.42rem, 1.55vw, 0.7rem);
    line-height: 1.15;
    color: var(--phosphor);
    text-shadow: var(--glow-strong);
    overflow: hidden;
  }
  .wordmark {
    font-family: var(--mono);
    font-size: 0.72rem;
    letter-spacing: 0.5em;
    text-transform: uppercase;
    color: var(--amber);
    text-shadow: var(--glow-amber);
    margin: 0 0 0.9rem;
    font-weight: 500;
  }
  .headline {
    font-size: clamp(1.9rem, 4vw, 2.6rem);
    line-height: 1.08;
    font-weight: 800;
    letter-spacing: -0.03em;
    color: var(--ink);
    margin: 0 0 0.75rem;
    max-width: 22ch;
  }
  .enemy {
    font-size: clamp(1.05rem, 2.2vw, 1.2rem);
    line-height: 1.45;
    font-weight: 600;
    color: var(--phosphor);
    text-shadow: var(--glow);
    margin: 0 0 1.1rem;
    max-width: 34ch;
  }
  .pitch {
    font-size: 1.02rem;
    line-height: 1.55;
    font-weight: 500;
    color: var(--ink);
    margin: 0 0 0.6rem;
    max-width: 34rem;
  }
  .sub {
    color: var(--muted);
    font-size: 0.98rem;
    margin: 0 0 1.75rem;
    max-width: 34rem;
  }
  .install {
    display: flex;
    align-items: stretch;
    gap: 0;
    margin: 0 0 1.4rem;
    max-width: 100%;
  }
  .install-cmd {
    margin: 0;
    background: var(--bg-inset);
    border: 1px solid var(--border);
    padding: 0.6rem 0.9rem;
    overflow-x: auto;
  }
  .install-cmd code {
    font-size: 0.9rem;
    color: var(--phosphor);
    text-shadow: var(--glow);
    white-space: nowrap;
  }
  .copy {
    font-family: var(--mono);
    font-size: 0.85rem;
    background: var(--bg-raised);
    color: var(--amber);
    border: 1px solid var(--border);
    border-left: 0;
    padding: 0 0.8rem;
    cursor: pointer;
    white-space: nowrap;
  }
  .copy:hover {
    background: var(--amber);
    color: #0a0700;
  }
  .cta {
    display: flex;
    gap: 0.6rem;
    flex-wrap: wrap;
    margin: 0;
    font-family: var(--mono);
  }
  .button {
    color: var(--amber);
    font-size: 0.92rem;
    padding: 0.15rem 0.2rem;
  }
  .button:hover {
    background: var(--amber);
    color: #0a0700;
    text-decoration: none;
  }

  /* ---- Trust strip ---- */
  .trust {
    margin: 2rem 0 0;
    padding-top: 1.5rem;
    border-top: 1px solid var(--border-dim);
  }
  .trust-label {
    font-family: var(--mono);
    font-size: 0.72rem;
    text-transform: uppercase;
    letter-spacing: 0.15em;
    color: var(--muted);
  }
  .trust-agents {
    list-style: none;
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem 1.1rem;
    margin: 0.6rem 0 0.9rem;
    padding: 0;
  }
  .trust-agents li {
    font-family: var(--mono);
    font-size: 0.9rem;
    color: var(--ink);
    font-weight: 600;
  }
  .trust-agents li::before {
    content: 'в–ё ';
    color: var(--phosphor);
  }
  .trust-note {
    margin: 0;
    font-size: 0.9rem;
    color: var(--muted);
    max-width: 34rem;
  }

  /* ---- Feature grid (the four levers) ---- */
  .lever-grid {
    list-style: none;
    padding: 0;
    margin: 1.4rem 0 0;
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(15rem, 1fr));
    gap: 0.9rem;
  }
  .lever-card {
    position: relative;
    border: 1px solid var(--border);
    background: var(--bg-inset);
    padding: 1.3rem 1.2rem 1.15rem;
    display: flex;
    flex-direction: column;
    gap: 0.4rem;
  }
  .lever-card:hover {
    border-color: var(--phosphor);
    box-shadow: 0 0 20px rgba(61, 255, 112, 0.1);
  }
  .lever-no {
    font-family: var(--mono);
    font-size: 0.72rem;
    color: var(--amber);
    letter-spacing: 0.1em;
  }
  .lever-card h3 {
    font-family: var(--mono);
    font-size: 1rem;
    color: var(--phosphor);
    text-shadow: var(--glow);
    text-transform: uppercase;
    letter-spacing: 0.04em;
    margin: 0;
  }
  .lever-card p {
    margin: 0;
    color: var(--muted);
    font-size: 0.92rem;
    line-height: 1.55;
    flex: 1;
  }
  .lever-link {
    font-family: var(--mono);
    font-size: 0.82rem;
    color: var(--amber);
    margin-top: 0.3rem;
  }

  /* ---- Before / after comparison ---- */
  .compare-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 0.9rem;
    margin: 1.4rem 0 0;
  }
  @media (min-width: 44rem) {
    .compare-grid {
      grid-template-columns: 1fr 1fr;
    }
  }
  .compare-col {
    border: 1px solid var(--border);
    background: var(--bg-inset);
    padding: 1.2rem 1.3rem 1.4rem;
  }
  .compare-col.without {
    border-color: rgba(255, 92, 92, 0.35);
  }
  .compare-col.with {
    border-color: var(--border);
  }
  .compare-col h3 {
    font-size: 1rem;
    margin: 0 0 0.9rem;
    display: flex;
    align-items: center;
    gap: 0.5rem;
  }
  .compare-col .mark {
    font-family: var(--mono);
  }
  .compare-col.without .mark {
    color: var(--red);
    text-shadow: 0 0 8px rgba(255, 92, 92, 0.35);
  }
  .compare-col.with .mark {
    color: var(--phosphor);
    text-shadow: var(--glow);
  }
  .compare-col ul {
    list-style: none;
    padding: 0;
    margin: 0;
    display: grid;
    gap: 0.6rem;
  }
  .compare-col li {
    font-size: 0.92rem;
    line-height: 1.5;
    color: var(--ink);
    padding-left: 1.2rem;
    position: relative;
  }
  .compare-col.without li::before {
    content: 'Г—';
    position: absolute;
    left: 0;
    color: var(--red);
  }
  .compare-col.with li::before {
    content: 'вҖә';
    position: absolute;
    left: 0;
    color: var(--phosphor);
  }
  .compare-col.with code {
    font-family: var(--mono);
    font-size: 0.86rem;
    color: var(--phosphor);
  }

  /* ---- Terminal frames ---- */
  .terminal {
    background: var(--bg-inset);
    border: 1px solid var(--border);
    box-shadow:
      0 0 0 1px rgba(0, 0, 0, 0.6),
      0 0 34px rgba(61, 255, 112, 0.07),
      0 18px 50px rgba(0, 0, 0, 0.5);
    overflow: hidden;
  }
  .terminal-bar {
    display: flex;
    align-items: center;
    gap: 0.45rem;
    padding: 0.55rem 1rem;
    background: var(--bg-raised);
    border-bottom: 1px solid var(--border-dim);
  }
  .dot {
    width: 0.65rem;
    height: 0.65rem;
    border-radius: 50%;
    background: var(--border);
  }
  .dot.red { background: #a33; }
  .dot.yellow { background: #a80; }
  .dot.green { background: #183; }
  .terminal-title {
    margin-left: 0.6rem;
    font-family: var(--mono);
    font-size: 0.78rem;
    color: var(--muted);
  }

  /* ---- Hero session (typed animation) ---- */
  .session {
    padding: 1.1rem 1.2rem 1.3rem;
    font-family: var(--mono);
    font-size: 0.92rem;
    line-height: 1.9;
    min-height: 15rem;
    /* Long command lines scroll like a real terminal вҖ” never clip silently. */
    overflow-x: auto;
  }
  @media (max-width: 30rem) {
    .session {
      font-size: 0.8rem;
    }
  }
  .line {
    white-space: pre-wrap;
    word-break: break-word;
  }
  .line.cmd {
    white-space: pre;
  }
  .line .txt {
    display: inline-block;
    overflow: hidden;
    white-space: pre;
    vertical-align: bottom;
  }
  .line.out.err {
    color: var(--red);
    text-shadow: 0 0 8px rgba(255, 92, 92, 0.35);
  }
  .line.out.ok {
