---
interface Props {
  title: string;
  description: string;
}
const { title, description } = Astro.props;
const repo = 'https://github.com/chalkagents/chalk-protocol';
const npm = 'https://www.npmjs.com/package/chalk-protocol';
const canonical = new URL(Astro.url.pathname, Astro.site);
---
<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="canonical" href={canonical} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonical} />
    <meta property="og:type" content="website" />
    <meta property="og:site_name" content="Chalk Protocol" />
    <meta name="twitter:card" content="summary" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <link rel="preload" href="/fonts/funnel-display.woff2" as="font" type="font/woff2" crossorigin />
    <link rel="preload" href="/fonts/space-grotesk.woff2" as="font" type="font/woff2" crossorigin />
  </head>
  <body>
    <header class="site-header">
      <nav class="site-nav">
        <a class="brand" href="/">chalk<span class="brand-dim">/protocol</span></a>
        <div class="nav-links">
          <a href="/protocol">protocol</a>
          <a href="/quickstart">quickstart</a>
          <a href="/research">research</a>
          <a class="nav-repo" href={repo}>github <span aria-hidden="true">→</span></a>
        </div>
      </nav>
    </header>
    <slot />
    <footer class="site-footer">
      <div class="footer-cols">
        <div class="footer-brand">
          <a class="brand" href="/">chalk<span class="brand-dim">/protocol</span></a>
          <p>The quality gate for AI coding agents. Built through chalk itself.</p>
        </div>
        <nav class="footer-col" aria-label="Docs">
          <h2>Docs</h2>
          <a href="/quickstart">Quickstart</a>
          <a href="/protocol">Protocol</a>
          <a href="/research">Research</a>
          <a href={npm}>npm package</a>
        </nav>
        <nav class="footer-col" aria-label="Community">
          <h2>Community</h2>
          <a href={repo}>GitHub</a>
          <a href={`${repo}/issues`}>Issues</a>
          <a href={`${repo}/blob/main/CONTRIBUTING.md`}>Contributing</a>
          <a href={`${repo}/blob/main/LICENSE`}>License</a>
        </nav>
      </div>
      <p class="status-bar">
        <span class="seg seg-name">chalk-protocol</span>
        <span class="seg seg-note">
          built through chalk itself — this site's own changes clear the same four gates.
          <a href={repo}>chalkagents/chalk-protocol</a>
        </span>
        <span class="seg seg-links">
          <a href={npm}>npm</a>
          <a href={repo}>github</a>
        </span>
      </p>
    </footer>
  </body>
</html>

<style is:global>
  /* Self-hosted fonts — no external runtime dependency (fonts.googleapis / gstatic).
     The site stays self-contained and offline-capable, matching its "built through
     chalk itself" ethos. Latin-subset variable woff2 in /public/fonts. */
  @font-face {
    font-family: 'Funnel Display';
    font-style: normal;
    font-weight: 300 700;
    font-display: swap;
    src: url('/fonts/funnel-display.woff2') format('woff2');
  }
  @font-face {
    font-family: 'JetBrains Mono';
    font-style: normal;
    font-weight: 300 600;
    font-display: swap;
    src: url('/fonts/jetbrains-mono.woff2') format('woff2');
  }
  @font-face {
    font-family: 'Space Grotesk';
    font-style: normal;
    font-weight: 300 600;
    font-display: swap;
    src: url('/fonts/space-grotesk.woff2') format('woff2');
  }
  :root {
    color-scheme: dark;
    /* Revyl-inspired: near-black canvas, ONE soft lavender accent, hairline borders,
       glows (never drop-shadows). Restraint is the whole trick. */
    --void: #050505;
    --panel: #0a0a0a;
    --panel-2: #111113;
    --fg: #ffffff;
    --fg2: #aaaaaa;
    --fg3: #6b7180;
    --faint: #333333;
    --border: rgba(255, 255, 255, 0.1);
    --border-strong: rgba(255, 255, 255, 0.18);
    --accent: #c4a1ff;
    --accent-deep: #b07fff;
    --accent-glow: rgba(196, 161, 255, 0.14);
    --accent-tint: rgba(196, 161, 255, 0.08);
    --ok: #4ade80;
    --err: #f87171;
    --display: 'Funnel Display', 'Space Grotesk', system-ui, sans-serif;
    --sans: 'Space Grotesk', system-ui, -apple-system, 'Segoe UI', sans-serif;
    --mono: 'JetBrains Mono', ui-monospace, 'SF Mono', Menlo, monospace;
    --maxw: 72rem;
  }
  * {
    box-sizing: border-box;
  }
  html {
    background: var(--void);
  }
  body {
    margin: 0;
    font-family: var(--sans);
    background: var(--void);
    color: var(--fg2);
    line-height: 1.7;
    -webkit-font-smoothing: antialiased;
    min-height: 100vh;
  }
  ::selection {
    background: var(--accent);
    color: #14101f;
  }
  a {
    color: var(--accent);
    text-decoration: none;
  }
  a:hover {
    color: var(--accent-deep);
  }
  h1,
  h2,
  h3 {
    color: var(--fg);
    font-weight: 500;
    letter-spacing: -0.01em;
  }
  code,
  pre,
  kbd {
    font-family: var(--mono);
  }

  /* Shared: the wide-tracked mono eyebrow that labels every section (HUD kicker). */
  .eyebrow {
    font-family: var(--mono);
    font-size: 0.7rem;
    text-transform: uppercase;
    letter-spacing: 0.2em;
    color: var(--fg3);
    margin: 0 0 1rem;
  }

  /* Header — minimal, hairline, blurred. */
  .site-header {
    position: sticky;
    top: 0;
    z-index: 20;
    background: rgba(5, 5, 5, 0.72);
    backdrop-filter: blur(10px);
    border-bottom: 1px solid var(--border);
  }
  .site-nav {
    max-width: var(--maxw);
    margin: 0 auto;
    padding: 0.9rem 1.5rem;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
  }
  .brand {
    font-family: var(--mono);
    font-size: 0.9rem;
    font-weight: 600;
    letter-spacing: 0.02em;
    color: var(--fg);
  }
  .brand:hover {
    color: var(--fg);
  }
  .brand-dim {
    color: var(--fg3);
  }
  .nav-links {
    display: flex;
    align-items: center;
    gap: 1.6rem;
    flex-wrap: wrap;
    font-family: var(--mono);
    font-size: 0.78rem;
    text-transform: uppercase;
    letter-spacing: 0.12em;
  }
  .nav-links a {
    color: var(--fg2);
  }
  .nav-links a:hover {
    color: var(--fg);
  }
  .nav-links a.nav-repo {
    color: var(--fg);
  }
  .nav-links a.nav-repo span {
    display: inline-block;
    transition: transform 0.15s ease;
  }
  .nav-links a.nav-repo:hover span {
    transform: translateX(3px);
  }

  /* Footer. */
  .site-footer {
    border-top: 1px solid var(--border);
    background: var(--void);
    font-size: 0.9rem;
    margin-top: 6rem;
  }
  .footer-cols {
    max-width: var(--maxw);
    margin: 0 auto;
    padding: 3.5rem 1.5rem 2.5rem;
    display: grid;
    grid-template-columns: 1fr;
    gap: 2.5rem;
  }
  @media (min-width: 44rem) {
    .footer-cols {
      grid-template-columns: 2fr 1fr 1fr;
    }
  }
  .footer-brand .brand {
    font-size: 1rem;
  }
  .footer-brand p {
    margin: 0.9rem 0 0;
    color: var(--fg3);
    max-width: 24rem;
    line-height: 1.7;
  }
  .footer-col h2 {
    font-family: var(--mono);
    font-size: 0.68rem;
    text-transform: uppercase;
    letter-spacing: 0.2em;
    color: var(--fg3);
    margin: 0 0 1rem;
    font-weight: 500;
  }
  .footer-col a {
    display: block;
    color: var(--fg2);
    padding: 0.25rem 0;
  }
  .footer-col a:hover {
    color: var(--accent);
  }
  .site-footer .status-bar {
    max-width: var(--maxw);
    margin: 0 auto;
    padding: 1.1rem 1.5rem;
    border-top: 1px solid var(--border);
    display: flex;
    align-items: baseline;
    gap: 1rem;
    flex-wrap: wrap;
    font-family: var(--mono);
    font-size: 0.72rem;
    color: var(--fg3);
  }
  .seg-name {
    color: var(--accent);
    letter-spacing: 0.08em;
  }
  .seg-note {
    flex: 1;
    min-width: 16rem;
  }
  .seg-links {
    display: flex;
    gap: 1rem;
    text-transform: uppercase;
    letter-spacing: 0.12em;
  }

  /* Shiki code blocks — dark palette, hairline HUD frame. */
  .astro-code,
  .astro-code span {
    color: var(--shiki-dark, inherit) !important;
    background-color: var(--shiki-dark-bg, transparent) !important;
  }
  .astro-code {
    background-color: var(--panel) !important;
    border: 1px solid var(--border);
    border-radius: 2px;
    padding: 0.95rem 1.1rem;
    overflow-x: auto;
    font-family: var(--mono);
    font-size: 0.88rem;
    line-height: 1.65;
  }
</style>
