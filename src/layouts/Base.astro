---
interface Props {
  title: string;
  description: string;
}
const { title, description } = Astro.props;
const repo = 'https://github.com/chalkagents/chalk-protocol';
const canonical = new URL(Astro.url.pathname, Astro.site);
---
<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="canonical" href={canonical} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonical} />
    <meta property="og:type" content="website" />
    <meta property="og:site_name" content="Chalk Protocol" />
    <meta name="twitter:card" content="summary" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
  </head>
  <body>
    <header class="site-header">
      <nav class="site-nav">
        <a class="brand" href="/">
          <span class="brand-mark" aria-hidden="true">▍</span>chalk<span class="brand-dim">-protocol</span>
        </a>
        <div class="nav-links">
          <a href="/protocol">Protocol</a>
          <a href="/quickstart">Quickstart</a>
          <a href="/research">Research</a>
          <a class="nav-repo" href={repo}>GitHub</a>
        </div>
      </nav>
    </header>
    <slot />
    <footer class="site-footer">
      <p>
        Built through chalk itself — this site's own changes clear the same four gates.
        <a href={repo}>chalkagents/chalk-protocol</a>
      </p>
    </footer>
  </body>
</html>

<style is:global>
  :root {
    color-scheme: dark;
    --bg: #0a0d13;
    --bg-raised: #10151f;
    --bg-inset: #0d1119;
    --border: #1f2634;
    --ink: #e8edf6;
    --muted: #949db3;
    --accent: #8ea7ff;
    --chalk: #6ee7b7;
    --mono: ui-monospace, 'SF Mono', 'Cascadia Code', 'JetBrains Mono', Menlo, Consolas, monospace;
    --sans: ui-sans-serif, system-ui, -apple-system, 'Segoe UI', sans-serif;
  }
  * {
    box-sizing: border-box;
  }
  body {
    margin: 0;
    font-family: var(--sans);
    background: var(--bg);
    color: var(--ink);
    line-height: 1.65;
    -webkit-font-smoothing: antialiased;
  }
  ::selection {
    background: rgba(110, 231, 183, 0.25);
  }
  a {
    color: var(--accent);
  }

  /* Site header */
  .site-header {
    position: sticky;
    top: 0;
    z-index: 10;
    background: rgba(10, 13, 19, 0.85);
    backdrop-filter: blur(8px);
    border-bottom: 1px solid var(--border);
  }
  .site-nav {
    max-width: 62rem;
    margin: 0 auto;
    padding: 0.85rem 1.5rem;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
  }
  .brand {
    font-family: var(--mono);
    font-weight: 700;
    font-size: 1rem;
    color: var(--ink);
    text-decoration: none;
    letter-spacing: -0.01em;
  }
  .brand-mark {
    color: var(--chalk);
    margin-right: 0.15rem;
  }
  .brand-dim {
    color: var(--muted);
    font-weight: 500;
  }
  .nav-links {
    display: flex;
    align-items: center;
    gap: 1.1rem;
    flex-wrap: wrap;
  }
  .nav-links a {
    color: var(--muted);
    text-decoration: none;
    font-size: 0.92rem;
    font-weight: 500;
  }
  .nav-links a:hover {
    color: var(--ink);
  }
  .nav-links a.nav-repo {
    color: var(--ink);
    border: 1px solid var(--border);
    border-radius: 0.45rem;
    padding: 0.25rem 0.7rem;
    background: var(--bg-raised);
  }
  .nav-links a.nav-repo:hover {
    border-color: var(--muted);
  }

  /* Site footer */
  .site-footer {
    border-top: 1px solid var(--border);
    color: var(--muted);
    font-size: 0.92rem;
  }
  .site-footer p {
    max-width: 62rem;
    margin: 0 auto;
    padding: 2rem 1.5rem 2.5rem;
  }
  .site-footer a {
    color: var(--accent);
    text-decoration: none;
  }
  .site-footer a:hover {
    text-decoration: underline;
  }

  /* Shiki dual-theme code blocks — the site is dark, so pin the dark palette. */
  .astro-code,
  .astro-code span {
    color: var(--shiki-dark, inherit) !important;
    background-color: var(--shiki-dark-bg, transparent) !important;
  }
  .astro-code {
    background-color: var(--bg-inset) !important;
    border: 1px solid var(--border);
    border-radius: 0.6rem;
    padding: 0.9rem 1.1rem;
    overflow-x: auto;
    font-family: var(--mono);
    font-size: 0.9rem;
    line-height: 1.6;
  }
</style>
