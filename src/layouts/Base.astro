---
interface Props {
  title: string;
  description: string;
}
const { title, description } = Astro.props;
const repo = 'https://github.com/chalkagents/chalk-protocol';
const npm = 'https://www.npmjs.com/package/chalk-protocol';
const canonical = new URL(Astro.url.pathname, Astro.site);
---
<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="canonical" href={canonical} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonical} />
    <meta property="og:type" content="website" />
    <meta property="og:site_name" content="Chalk Protocol" />
    <meta name="twitter:card" content="summary" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
  </head>
  <body>
    <header class="site-header">
      <nav class="site-nav">
        <a class="brand" href="/">
          <span class="brand-mark" aria-hidden="true">▍</span>chalk<span class="brand-dim">-protocol</span>
        </a>
        <div class="nav-links">
          <a href="/protocol">protocol</a>
          <a href="/quickstart">quickstart</a>
          <a href="/research">research</a>
          <a class="nav-repo" href={repo}>github ↗</a>
        </div>
      </nav>
    </header>
    <slot />
    <footer class="site-footer">
      <p class="status-bar">
        <span class="seg seg-name">chalk-protocol</span>
        <span class="seg seg-note">
          built through chalk itself — this site's own changes clear the same four gates.
          <a href={repo}>chalkagents/chalk-protocol</a>
        </span>
        <span class="seg seg-links">
          <a href={npm}>npm</a>
          <a href={repo}>github</a>
        </span>
      </p>
    </footer>
  </body>
</html>

<style is:global>
  :root {
    color-scheme: dark;
    /* Modern terminal: phosphor lives in the terminals; the page around them is calm.
       Prose is sans and near-white — mono is reserved for terminal content and labels. */
    --bg: #070c09;
    --bg-raised: #0b130e;
    --bg-inset: #060f09;
    --border: #17492a;
    --border-dim: #0f3520;
    --ink: #dfeae2;
    --muted: #7fa18c;
    --phosphor: #3dff70;
    --amber: #ffb000;
    --red: #ff5c5c;
    --accent: var(--amber);
    --chalk: var(--phosphor);
    --glow: 0 0 6px rgba(61, 255, 112, 0.45);
    --glow-strong: 0 0 4px rgba(61, 255, 112, 0.9), 0 0 18px rgba(61, 255, 112, 0.35);
    --glow-amber: 0 0 8px rgba(255, 176, 0, 0.45);
    --mono: ui-monospace, 'SF Mono', 'Cascadia Code', 'JetBrains Mono', Menlo, Consolas, monospace;
    --sans: ui-sans-serif, system-ui, -apple-system, 'Segoe UI', Roboto, 'Helvetica Neue', sans-serif;
  }
  * {
    box-sizing: border-box;
  }
  html {
    background: var(--bg);
  }
  body {
    margin: 0;
    font-family: var(--sans);
    background: radial-gradient(ellipse 120% 80% at 50% -10%, #0b1a0f 0%, var(--bg) 55%);
    color: var(--ink);
    line-height: 1.7;
    -webkit-font-smoothing: antialiased;
    min-height: 100vh;
  }
  /* CRT texture lives INSIDE terminal frames only — never over reading text. */
  .terminal {
    position: relative;
  }
  .terminal::after {
    content: '';
    position: absolute;
    inset: 0;
    z-index: 1; /* explicit — session lines animate opacity (own stacking contexts); paint order must not depend on tree order */
    pointer-events: none;
    background: repeating-linear-gradient(
      0deg,
      rgba(0, 0, 0, 0.16) 0px,
      rgba(0, 0, 0, 0.16) 1px,
      transparent 1px,
      transparent 3px
    );
  }
  ::selection {
    background: var(--phosphor);
    color: #041007;
    text-shadow: none;
  }
  a {
    color: var(--amber);
    text-decoration: none;
  }
  /* Safe default hover — the amber inversion is opt-in per component, NEVER global:
     scoped children that set their own color (docs pager titles, meta links) would
     render amber-on-amber against an inherited inverted background. */
  a:hover {
    text-decoration: underline;
  }
  h1,
  h2,
  h3 {
    font-family: var(--sans);
    color: var(--ink);
    font-weight: 700;
    letter-spacing: -0.015em;
  }
  code,
  pre,
  kbd {
    font-family: var(--mono);
  }

  /* Site header — a terminal tab bar (chrome stays mono; it IS terminal). */
  .site-header {
    position: sticky;
    top: 0;
    z-index: 10;
    background: rgba(7, 12, 9, 0.92);
    backdrop-filter: blur(6px);
    border-bottom: 1px solid var(--border-dim);
  }
  .site-nav {
    max-width: 68rem;
    margin: 0 auto;
    padding: 0.7rem 1.5rem;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
    font-family: var(--mono);
    font-size: 0.9rem;
  }
  .brand {
    font-weight: 700;
    color: var(--phosphor);
    text-shadow: var(--glow);
  }
  .brand:hover {
    background: transparent;
    color: var(--phosphor);
    text-decoration: none;
  }
  .brand-mark {
    animation: blink 1.1s step-end infinite;
  }
  .brand-dim {
    color: var(--muted);
    font-weight: 500;
    text-shadow: none;
  }
  .nav-links {
    display: flex;
    align-items: center;
    gap: 0.35rem;
    flex-wrap: wrap;
  }
  .nav-links a {
    color: var(--muted);
    padding: 0.1rem 0.55rem;
  }
  .nav-links a::before {
    content: '[';
    color: var(--border);
  }
  .nav-links a::after {
    content: ']';
    color: var(--border);
  }
  .nav-links a:hover {
    background: var(--amber);
    color: #0a0700;
    text-decoration: none;
  }
  .nav-links a:hover::before,
  .nav-links a:hover::after {
    color: #0a0700;
  }
  .nav-links a.nav-repo {
    color: var(--amber);
  }
  .nav-links a.nav-repo:hover {
    background: var(--amber);
    color: #0a0700;
    text-decoration: none;
  }

  /* Site footer — a tmux-style status bar. */
  .site-footer {
    border-top: 1px solid var(--border-dim);
    background: var(--bg-raised);
    font-family: var(--mono);
    font-size: 0.85rem;
  }
  .status-bar {
    max-width: 68rem;
    margin: 0 auto;
    padding: 0.8rem 1.5rem;
    display: flex;
    align-items: baseline;
    gap: 1rem;
    flex-wrap: wrap;
  }
  .seg-name {
    color: #041007;
    background: var(--phosphor);
    padding: 0 0.5rem;
    font-weight: 700;
  }
  .seg-note {
    color: var(--muted);
    flex: 1;
    min-width: 16rem;
  }
  .seg-links {
    display: flex;
    gap: 0.75rem;
  }
  .seg-links a::before {
    content: '[';
  }
  .seg-links a::after {
    content: ']';
  }
  .seg-links a:hover {
    background: var(--amber);
    color: #0a0700;
    text-decoration: none;
  }

  /* visibility, not opacity — the chrome test asserts opacity:0 never appears outside
     the reduced-motion guard, so nothing can accidentally hide content. */
  @keyframes blink {
    0%, 100% { visibility: visible; }
    50% { visibility: hidden; }
  }
  @media (prefers-reduced-motion: reduce) {
    .brand-mark {
      animation: none;
    }
  }

  /* Shiki dual-theme code blocks — pin the dark palette, frame like a readout. */
  .astro-code,
  .astro-code span {
    color: var(--shiki-dark, inherit) !important;
    background-color: var(--shiki-dark-bg, transparent) !important;
  }
  .astro-code {
    background-color: var(--bg-inset) !important;
    border: 1px solid var(--border-dim);
    border-radius: 0;
    padding: 0.9rem 1.1rem;
    overflow-x: auto;
    font-family: var(--mono);
    font-size: 0.9rem;
    line-height: 1.6;
  }
</style>
